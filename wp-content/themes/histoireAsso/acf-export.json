[
    {
        "key": "group_event_fields",
        "title": "Événement - Informations",
        "fields": [
            {
                "key": "field_date_event",
                "label": "Date de l'événement",
                "name": "date_event",
                "type": "date_picker",
                "instructions": "Date à laquelle l'événement aura lieu",
                "required": 1,
                "display_format": "d\/m\/Y",
                "return_format": "Y-m-d",
                "first_day": 1
            },
            {
                "key": "field_lieu",
                "label": "Lieu",
                "name": "lieu",
                "type": "text",
                "instructions": "Localisation de l'événement (ville, adresse)",
                "required": 0,
                "placeholder": "Ex: Tournai, Belgique"
            },
            {
                "key": "field_galerie_event",
                "label": "Galerie Photos",
                "name": "galerie",
                "type": "gallery",
                "instructions": "Photos de l'événement (plusieurs images possibles pour carousel)",
                "required": 0,
                "return_format": "array",
                "preview_size": "medium",
                "insert": "append",
                "library": "all",
                "min": 0,
                "max": 20
            }
        ],
        "location": [
            [
                {
                    "param": "post_type",
                    "operator": "==",
                    "value": "event"
                }
            ]
        ],
        "menu_order": 0,
        "position": "normal",
        "style": "default",
        "label_placement": "top",
        "instruction_placement": "label",
        "active": true
    },
